{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ELMS Dummy Client",
  "version": "0.1.0",
  "identifier": "com.elms.desktop.dummy",
  "build": {
    "beforeDevCommand": "node ./scripts/frontend-dummy-dev.mjs",
    "beforeBuildCommand": "node ./scripts/prepare-dummy-desktop-build.mjs",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../../packages/frontend/dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self' tauri: asset:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self' asset: data:; img-src 'self' asset: data: blob:; connect-src 'self' http://* https://* ws://* wss://*"
    },
    "windows": [
      {
        "title": "ELMS Dummy Client",
        "width": 1440,
        "height": 960,
        "resizable": true,
        "visible": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../packages/frontend/dist": "packages/frontend/dist/"
    },
    "windows": {
      "nsis": {
        "languages": ["English"],
        "installMode": "perMachine"
      },
      "wix": {
        "language": "en-US"
      }
    }
  }
}

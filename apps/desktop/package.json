{
  "name": "@elms/desktop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "compile": "pnpm cargo:check",
    "cargo:check": "node ./scripts/cargo-runner.mjs check",
    "lint": "cargo fmt --manifest-path src-tauri/Cargo.toml --check && node ./scripts/cargo-runner.mjs clippy",
    "typecheck": "pnpm cargo:check",
    "test": "node ./scripts/cargo-runner.mjs test",
    "tauri": "node ./scripts/tauri-wrapper.mjs",
    "tauri:dev": "tauri dev",
    "tauri:dev:dummy": "DESKTOP_RUNTIME_VARIANT=dummy tauri dev -c src-tauri/tauri.dummy.conf.json",
    "package:binary": "pnpm tauri build --no-bundle --ci",
    "package:binary:dummy": "DESKTOP_RUNTIME_VARIANT=dummy tauri build --no-bundle --ci -c src-tauri/tauri.dummy.conf.json",
    "package:linux": "bash ../../scripts/package-desktop-linux.sh",
    "package:windows:cross": "bash ../../scripts/package-desktop-windows-cross.sh"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.2"
  }
}

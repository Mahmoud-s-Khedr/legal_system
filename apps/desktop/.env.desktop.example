NODE_ENV=development

# Target behavior
AUTH_MODE=local
STORAGE_DRIVER=local

# Network
HOST=127.0.0.1
BACKEND_PORT=7854
FRONTEND_PORT=5173

# Datastores
DATABASE_URL=postgresql://elms:elms@127.0.0.1:5433/elms_desktop?schema=public
# REDIS_URL is not used in AUTH_MODE=local (no cloud sessions or BullMQ)
REDIS_URL=redis://127.0.0.1:6379

# Auth — session
COOKIE_DOMAIN=localhost
LOCAL_SESSION_TTL_HOURS=12
# JWT TTLs below are unused in AUTH_MODE=local but kept so the schema parses cleanly
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# Desktop runtime
DESKTOP_FRONTEND_URL=http://127.0.0.1:5173
DESKTOP_BACKEND_URL=http://127.0.0.1:7854
DESKTOP_POSTGRES_PORT=5433
# Placeholder — set when distributing a signed build
DESKTOP_LICENSE_PUBLIC_KEY=
# Placeholder — set to enable OTA auto-updates
DESKTOP_UPDATE_MANIFEST_URL=

# Default setup credentials (development only)
VITE_SETUP_EMAIL=admin@elms.local
VITE_SETUP_PASSWORD=password123
VITE_FOOTER_NAME=Mahmoud Khedr
VITE_FOOTER_EMAIL=mahmoud.s.khedr.2@gmail.com
VITE_FOOTER_PHONE=01016240934
VITE_FOOTER_LINKEDIN=https://www.linkedin.com/in/mahmoud-s-khedr/

# File storage (desktop uses local filesystem)
MAX_UPLOAD_BYTES=52428800
LOCAL_STORAGE_PATH=./uploads
OCR_BACKEND=tesseract

{
  "name": "@elms/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "pnpm build",
    "dev": "vite",
    "dev:desktop": "vite --host 127.0.0.1 --port 5173",
    "build": "tsc -p tsconfig.json && vite build",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:tokens": "node ./scripts/check-tailwind-tokens.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "i18n:check": "node ./scripts/check-i18n-keys.mjs"
  },
  "dependencies": {
    "@elms/shared": "workspace:*",
    "@fontsource/cairo": "^5.2.7",
    "@fontsource/noto-naskh-arabic": "^5.2.11",
    "@sentry/react": "^10.22.0",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-router": "^1.134.2",
    "@tauri-apps/api": "^2.8.0",
    "i18next": "^25.6.0",
    "lucide-react": "^0.577.0",
    "pdfjs-dist": "^5.5.207",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.1.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "tailwindcss-rtl": "^0.9.0",
    "vite": "^7.1.12",
    "vite-plugin-pwa": "^0.21.1"
  }
}

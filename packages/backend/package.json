{
  "name": "@elms/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/cloud/server.js",
  "types": "dist/cloud/server.d.ts",
  "scripts": {
    "dev": "node ./scripts/dev-local.mjs",
    "dev:cloud": "node ./scripts/dev-local.mjs ../../archive/cloud/apps/web/.env.cloud",
    "dev:local": "node ./scripts/dev-local.mjs ../../apps/desktop/.env.desktop",
    "compile": "pnpm build",
    "build": "tsup --clean",
    "build:desktop": "node ./scripts/build-desktop.mjs",
    "lint": "eslint src prisma --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prisma": "prisma",
    "seed": "tsx prisma/seed.ts",
    "seed:dev": "node --env-file ../../apps/desktop/.env.desktop --import tsx/esm prisma/seed.ts",
    "seed:dev:cloud": "node --import tsx/esm prisma/seed.ts",
    "deploy": "pnpm deploy"
  },
  "dependencies": {
    "html-to-docx": "^1.8.0",
    "@anthropic-ai/sdk": "^0.54.0",
    "@aws-sdk/client-s3": "^3.1013.0",
    "@aws-sdk/s3-request-presigner": "^3.1013.0",
    "@elms/shared": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.2.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@google-cloud/vision": "^5.3.5",
    "@napi-rs/canvas": "^0.1.97",
    "@prisma/client": "^6.18.0",
    "prisma": "^6.18.0",
    "@sentry/node": "^10.22.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.0",
    "exceljs": "^4.4.0",
    "fastify": "^5.6.1",
    "file-type": "^21.3.3",
    "ioredis": "^5.8.2",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.10",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.5.207",
    "pdfmake": "^0.2.20",
    "tesseract.js": "^7.0.0",
    "twilio": "^5.10.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/exceljs": "^1.3.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.3",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfmake": "^0.2.12",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6"
  }
}

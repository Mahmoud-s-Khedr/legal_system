{
  "name": "elms",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "pnpm dev:tauri",
    "dev:full": "concurrently \"pnpm dev:web\" \"pnpm dev:tauri\"",
    "dev:web": "concurrently \"pnpm --filter @elms/backend dev:cloud\" \"pnpm --filter @elms/frontend dev --port 5174\"",
    "dev:desktop": "concurrently \"pnpm --filter @elms/backend dev:local\" \"pnpm --filter @elms/frontend dev:desktop\"",
    "dev:tauri": "pnpm --filter @elms/desktop tauri:dev",
    "build": "pnpm compile",
    "compile": "turbo run compile",
    "validate": "pnpm check:lockfile && pnpm prisma:generate && pnpm lint && pnpm i18n:check && pnpm typecheck && pnpm test && pnpm test:coverage",
    "check:lockfile": "bash ./scripts/check-lockfile.sh",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "pnpm --filter @elms/shared test:coverage",
    "test:backend": "pnpm --filter @elms/backend test",
    "test:frontend": "pnpm --filter @elms/frontend test",
    "test:shared": "pnpm --filter @elms/shared test",
    "test:e2e": "playwright test",
    "test:load": "k6 run tests/load/api-baseline.js",
    "test:load:auth": "k6 run tests/load/auth.js",
    "test:load:upload": "k6 run tests/load/document-upload.js",
    "format:check": "prettier --check .",
    "prisma:generate": "pnpm --filter @elms/backend prisma generate",
    "prisma:seed": "pnpm --filter @elms/backend prisma db seed",
    "check:desktop:packaging-host": "bash ./scripts/check-desktop-packaging-host.sh",
    "release:desktop:linux": "DESKTOP_RELEASE_TARGETS=linux bash ./scripts/release-desktop-local.sh",
    "release:desktop:local": "bash ./scripts/release-desktop-local.sh",
    "release:web": "pnpm --filter @elms/web docker:build:backend && pnpm --filter @elms/web docker:build:frontend",
    "seed:dev": "NODE_ENV=development pnpm --filter @elms/backend seed:dev",
    "seed:dev:cloud": "DATABASE_URL=postgresql://elms:elms@127.0.0.1:5432/elms_cloud?schema=public NODE_ENV=development pnpm --filter @elms/backend seed:dev:cloud",
    "i18n:check": "pnpm --filter @elms/frontend i18n:check",
    "docs:verify": "node ./scripts/docs/verify-docs-truth.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.8.1",
    "@vitest/coverage-v8": "^3.2.4",
    "7zip-bin": "^5.2.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.6.2",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^3.2.4"
  }
}

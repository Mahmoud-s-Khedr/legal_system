NODE_ENV=development

# Target behavior
AUTH_MODE=cloud
STORAGE_DRIVER=local

# Shared application ports
HOST=0.0.0.0
BACKEND_PORT=7854
FRONTEND_PORT=5173
VITE_API_BASE_URL=/api
VITE_SENTRY_DSN=
VITE_FOOTER_NAME=Mahmoud Khedr
VITE_FOOTER_EMAIL=mahmoud.s.khedr.2@gmail.com
VITE_FOOTER_PHONE=01016240934
VITE_FOOTER_LINKEDIN=https://www.linkedin.com/in/mahmoud-s-khedr/
DESKTOP_FRONTEND_URL=http://127.0.0.1:5173
DESKTOP_BACKEND_URL=http://127.0.0.1:7854
DESKTOP_POSTGRES_PORT=5433

# Datastores
DATABASE_URL=postgresql://elms:elms@127.0.0.1:5432/elms_cloud?schema=public
REDIS_URL=redis://127.0.0.1:6379

# Auth
COOKIE_DOMAIN=localhost
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
LOCAL_SESSION_TTL_HOURS=12
# REQUIRED in production — generate with: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048
JWT_PRIVATE_KEY=
# REQUIRED in production — derive from private key with: openssl rsa -pubout
JWT_PUBLIC_KEY=
# Comma-separated list of allowed CORS origins in production (e.g. https://elms.firm.com)
ALLOWED_ORIGINS=

# File storage
MAX_UPLOAD_BYTES=52428800
LOCAL_STORAGE_PATH=./uploads
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_DOMAIN=

# OCR and AI
OCR_BACKEND=tesseract
GOOGLE_VISION_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Maximum AI research messages per firm per month (0 = unlimited)
AI_MONTHLY_LIMIT=500

# Cloud services
RESEND_API_KEY=
CONNECT_MISR_API_KEY=
PAYMOB_API_KEY=
SENTRY_DSN=

# Email (SMTP) — used for notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@elms.app

# SMS — set SMS_PROVIDER=twilio to enable
SMS_PROVIDER=none
SMS_ACCOUNT_SID=
SMS_AUTH_TOKEN=
SMS_FROM_NUMBER=

# Desktop distribution
# Required for production desktop licensing verification.
# Accepts either:
# 1) raw PEM public key text, or
# 2) base64-encoded PEM public key.
DESKTOP_LICENSE_PUBLIC_
DESKTOP_UPDATE_MANIFEST_URL=
